# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Database -------------------------------------------------------------
# Matches docker-compose.yml. Host port is 5433, not 5432.
DATABASE_URL=postgresql+psycopg2://pmpilot:pmpilot_dev@localhost:5433/pmpilot

# Read-only connection used ONLY to execute NL2SQL-generated queries.
# See .claude/rules/security.md — this is a required defence layer, not an option.
DATABASE_URL_READONLY=postgresql+psycopg2://pmpilot_ro:pmpilot_ro_dev@localhost:5433/pmpilot

# --- LLM ------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Pinned for the whole project. Changing this mid-project makes the grounded and
# naive experiment arms incomparable — see .claude/rules/experiment.md.
ANTHROPIC_MODEL_ID=claude-opus-4-8

# low | medium | high | xhigh | max. Controls reasoning depth and token spend.
# There is no `temperature` on this model — it is rejected with a 400.
ANTHROPIC_EFFORT=high
